# Sandbox Environment Configuration
# Copy this file to .env.sandbox and fill in the actual values
# This is used for sandbox deployments (sandbox.meant2grow.com)

# Google OAuth Client ID (Sandbox)
# Get this from Google Cloud Console > APIs & Services > Credentials
# Use the OAuth 2.0 Client ID configured for sandbox.meant2grow.com
VITE_GOOGLE_CLIENT_ID=YOUR_SANDBOX_GOOGLE_CLIENT_ID_HERE

# Firebase Config (Sandbox - meant2grow-dev project)
# Get these from Firebase Console > Project Settings > General > Your apps > Web app
# Project: meant2grow-dev
VITE_FIREBASE_API_KEY=YOUR_SANDBOX_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=sandbox.meant2grow.com
VITE_FIREBASE_PROJECT_ID=meant2grow-dev
VITE_FIREBASE_STORAGE_BUCKET=meant2grow-dev.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SANDBOX_SENDER_ID_HERE
VITE_FIREBASE_APP_ID=YOUR_SANDBOX_APP_ID_HERE

# Firebase Cloud Messaging VAPID Key (for push notifications)
# Generate this key in Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
# Click "Generate key pair" and copy the key here
VITE_FIREBASE_VAPID_KEY=YOUR_SANDBOX_VAPID_KEY_HERE

# Functions URL (Sandbox)
VITE_FUNCTIONS_URL=https://us-central1-meant2grow-dev.cloudfunctions.net

# App URL (Sandbox)
VITE_APP_URL=https://sandbox.meant2grow.com

# Transactional email is sent from Firebase Cloud Functions (RESEND_API_KEY default, optional MAILERSEND_API_TOKEN backup, MAILERSEND_FROM_EMAIL / MAILERSEND_REPLY_TO_EMAIL), not from Vite env.

# GIPHY API Key (for GIF picker in chat)
# Get your free API key from: https://developers.giphy.com/
VITE_GIPHY_API_KEY=your_giphy_api_key_here

# Flowglad Configuration (Billing & Payments)
# Get your API keys from: https://app.flowglad.com/settings/api-keys
# Use sandbox/test keys for sandbox environment
FLOWGLAD_SECRET_KEY=your_sandbox_flowglad_key_here
FLOWGLAD_WEBHOOK_SECRET=whsec_your_sandbox_webhook_secret_here

# Flowglad Price IDs (create these in your Flowglad dashboard)
# Use sandbox/test price IDs for sandbox environment
FLOWGLAD_PRICE_STARTER_MONTHLY=price_sandbox_starter_monthly
FLOWGLAD_PRICE_STARTER_YEARLY=price_sandbox_starter_yearly
FLOWGLAD_PRICE_PRO_MONTHLY=price_sandbox_pro_monthly
FLOWGLAD_PRICE_PRO_YEARLY=price_sandbox_pro_yearly
FLOWGLAD_PRICE_BUSINESS_MONTHLY=price_sandbox_business_monthly
FLOWGLAD_PRICE_BUSINESS_YEARLY=price_sandbox_business_yearly
