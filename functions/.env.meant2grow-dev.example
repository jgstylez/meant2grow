# Google Service Account Email
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Resend (default transactional provider)
# https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# MailerSend — optional fallback when using Resend, or set EMAIL_PROVIDER=mailersend for MailerSend-only
# https://app.mailersend.com/api-tokens
MAILERSEND_API_TOKEN=your_mailersend_api_token_here
MAILERSEND_FROM_EMAIL=noreply@meant2grow.com
MAILERSEND_REPLY_TO_EMAIL=support@meant2grow.com

# EMAIL_PROVIDER=resend

# App URL
VITE_APP_URL=https://sandbox.meant2grow.com
