rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== HELPER FUNCTIONS ====================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user document exists
    function userExists() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    // Get the current user's document data (only call if userExists() is true)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Check if user belongs to specific organization
    function belongsToOrg(organizationId) {
      return isAuthenticated() && 
             userExists() &&
             getUserData().organizationId != null &&
             getUserData().organizationId == organizationId;
    }
    
    // Check if user is organization admin
    // Also check for 'ADMIN' role for backwards compatibility
    function isOrgAdmin(organizationId) {
      return isAuthenticated() && 
             userExists() &&
             belongsToOrg(organizationId) &&
             (getUserData().role == 'ORGANIZATION_ADMIN' ||
              getUserData().role == 'ADMIN');
    }
    
    // Check if user is platform operator
    function isPlatformOperator() {
      return isAuthenticated() && 
             userExists() &&
             (getUserData().role == 'PLATFORM_OPERATOR' || 
              getUserData().organizationId == 'platform');
    }
    
    // Owns resource by userId field, or legacy users/{randomId} with firebaseAuthUid == request.auth.uid
    function isOwner(userId) {
      return isAuthenticated() && (
        request.auth.uid == userId ||
        (
          exists(/databases/$(database)/documents/users/$(userId)) &&
          get(/databases/$(database)/documents/users/$(userId)).data.get('firebaseAuthUid', '') == request.auth.uid
        )
      );
    }
    
    // users/{profileDocId} belongs to organizationId and caller is that profile (doc id or linked firebaseAuthUid).
    function profileDocActsForOrg(profileDocId, organizationId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(profileDocId)) &&
        get(/databases/$(database)/documents/users/$(profileDocId)).data.organizationId == organizationId &&
        (
          request.auth.uid == profileDocId ||
          get(/databases/$(database)/documents/users/$(profileDocId)).data.get('firebaseAuthUid', '') == request.auth.uid
        );
    }
    
    // Check if document belongs to user's organization
    // Platform operators can access all documents regardless of organizationId
    function isOrgScoped(organizationId) {
      return isPlatformOperator() || belongsToOrg(organizationId);
    }

    // Anonymous signup: only Pending -> Accepted or Expired, status field only
    function unauthInvitationStatusUpdate() {
      return request.auth == null &&
        resource.data.status == 'Pending' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        (request.resource.data.status == 'Accepted' || request.resource.data.status == 'Expired');
    }
    
    // Validate organization data on create
    function isValidOrganization() {
      let data = request.resource.data;
      return data.name is string && 
             data.name.size() > 0 &&
             data.createdAt is timestamp &&
             data.organizationCode is string &&
             data.organizationCode.size() > 0 &&
             (!exists(data.subscriptionTier) || 
              data.subscriptionTier in ['free', 'starter', 'professional', 'business', 'enterprise']);
    }
    
    // Validate user data on create
    function isValidUser() {
      let data = request.resource.data;
      // Basic email validation (contains @ and .)
      let emailValid = data.email is string && 
                       data.email.size() > 0 &&
                       data.email.matches('.*@.*\\..*');
      return data.organizationId is string &&
             data.organizationId.size() > 0 &&
             data.name is string &&
             data.name.size() > 0 &&
             emailValid &&
             data.role is string &&
             data.role.size() > 0 &&
             data.createdAt is timestamp;
    }
    
    // ==================== ORGANIZATIONS ====================
    
    match /organizations/{orgId} {
      // Allow unauthenticated users to create organizations (for signup) with validation
      // Also allow authenticated users to create organizations with validation
      allow create: if isValidOrganization();
      
      // Users can read their own organization, platform operators can read all
      // Also allow unauthenticated reads for organization code lookups during signup
      allow read: if belongsToOrg(orgId) || 
                     isPlatformOperator() ||
                     // Allow unauthenticated reads for signup flow (organization code lookups)
                     request.auth == null;
      
      // Allow updates during signup (for setting trial info) or by org admins/platform admins
      allow update: if request.auth == null || // Allow during signup flow
                     isOrgAdmin(orgId) || 
                     isPlatformOperator();
      
      // Only platform operators can delete organizations
      allow delete: if isPlatformOperator();
    }
    
    // ==================== USERS ====================
    
    match /users/{userId} {
      // Allow unauthenticated users to create accounts (for signup) with validation
      // Also allow authenticated users to create users with validation
      allow create: if isValidUser();
      
      // Users can read users in their organization, or their own profile, platform operators can read all
      // Also allow unauthenticated reads for email lookups during login
      // Note: This allows checking if an email exists, which is needed for login but is a minor security trade-off
      // IMPORTANT: Check isPlatformOperator() FIRST for better performance in collection queries
      // Platform operators should be able to read all users without organization filtering
      // Allow reading doc when firebaseAuthUid matches (legacy docs at users/randomId, e.g. platform operators)
      allow read: if isPlatformOperator() ||
                     belongsToOrg(resource.data.organizationId) || 
                     request.auth.uid == userId || 
                     (resource.data.firebaseAuthUid != null && resource.data.firebaseAuthUid == request.auth.uid) ||
                     // Allow unauthenticated reads for login flow (email lookups)
                     request.auth == null;
      
      // Users can update their own profile, org admins can update users in their org, platform operators can update any
      // Allow adding firebaseAuthUid to legacy docs (created with random ID) - only when doc doesn't have it yet
      // Owner updates when doc id is legacy random id but firebaseAuthUid matches signed-in user (mirrors read rule)
      // Link firebaseAuthUid on legacy random-id docs: `exists()` is for paths only, not map keys.
      allow update: if request.auth.uid == userId ||
                     ((!resource.data.keys().hasAny(['firebaseAuthUid']) || resource.data.firebaseAuthUid == null) && request.resource.data.firebaseAuthUid == request.auth.uid) ||
                     (resource.data.firebaseAuthUid != null && resource.data.firebaseAuthUid == request.auth.uid) ||
                     (belongsToOrg(resource.data.organizationId) && isOrgAdmin(resource.data.organizationId)) ||
                     isPlatformOperator();
      
      // Platform operators can delete any user.
      // Authenticated users may delete a legacy duplicate profile doc (random id) after linking to Firebase Auth UID.
      allow delete: if isPlatformOperator() ||
        (isAuthenticated() &&
         resource.data.get('firebaseAuthUid', '') == request.auth.uid &&
         userId != request.auth.uid);
    }
    
    // ==================== MATCHES ====================
    
    match /matches/{matchId} {
      // Users can create matches in their organization, platform admins can create anywhere
      // Platform admins can create matches in any organization (including when impersonating)
      // Regular users (including org admins) can create matches in their own organization
      // Note: When impersonating, the authenticated user is the original operator.
      //       If the original operator is a platform admin, isPlatformOperator() will allow creation.
      //       If the original operator is an org admin in the target org, belongsToOrg() will allow creation.
      allow create: if isAuthenticated() && 
                      (isPlatformOperator() || 
                       belongsToOrg(request.resource.data.organizationId));
      
      // Users can read matches in their organization, platform operators can read all
      allow read: if isPlatformOperator() || isOrgScoped(resource.data.organizationId);
      
      // Users can update matches in their organization (participants or org admins)
      // Platform operators can update any match
      allow update: if isPlatformOperator() ||
                      (isOrgScoped(resource.data.organizationId) &&
                       (isOwner(resource.data.mentorId) ||
                        isOwner(resource.data.menteeId) ||
                        isOrgAdmin(resource.data.organizationId)));
      
      // Users can delete matches they're part of, or org admins can delete in their org
      // Platform operators can delete any match
      allow delete: if isPlatformOperator() ||
                      (isOrgScoped(resource.data.organizationId) &&
                       (isOwner(resource.data.mentorId) ||
                        isOwner(resource.data.menteeId) ||
                        isOrgAdmin(resource.data.organizationId)));
    }
    
    // ==================== GOALS ====================
    
    match /goals/{goalId} {
      // Users can create goals in their organization, platform operators can create anywhere
      allow create: if isAuthenticated() && 
                      (isPlatformOperator() || 
                       belongsToOrg(request.resource.data.organizationId) ||
                       profileDocActsForOrg(request.resource.data.userId, request.resource.data.organizationId));
      
      // Users can read goals in their organization, platform operators can read all
      allow read: if isPlatformOperator() || isOrgScoped(resource.data.organizationId);
      
      // Users can update their own goals, or org admins can update any in their org
      // Platform operators can update any goal
      allow update: if isPlatformOperator() ||
                      (isOrgScoped(resource.data.organizationId) &&
                       (isOwner(resource.data.userId) ||
                        isOrgAdmin(resource.data.organizationId)));
      
      // Users can delete their own goals, or org admins can delete any in their org
      // Platform operators can delete any goal
      allow delete: if isPlatformOperator() ||
                      (isOrgScoped(resource.data.organizationId) &&
                       (isOwner(resource.data.userId) ||
                        isOrgAdmin(resource.data.organizationId)));
    }
    
    // ==================== MILESTONES ====================
    
    match /milestones/{milestoneId} {
      // Users can create milestones in their organization
      allow create: if isAuthenticated() && 
                      belongsToOrg(request.resource.data.organizationId);
      
      // Users can read milestones in their organization
      allow read: if isOrgScoped(resource.data.organizationId);
      
      // Users can update milestones in their organization
      allow update: if isOrgScoped(resource.data.organizationId);
      
      // Users can delete milestones in their organization
      allow delete: if isOrgScoped(resource.data.organizationId);
    }
    
    // ==================== CALENDAR EVENTS ====================
    
    match /calendarEvents/{eventId} {
      // Users can create events in their organization, platform operators can create anywhere
      allow create: if isAuthenticated() && 
                      (isPlatformOperator() || belongsToOrg(request.resource.data.organizationId));
      
      // Users can read events in their organization, platform operators can read all
      allow read: if isPlatformOperator() || isOrgScoped(resource.data.organizationId);
      
      // Users can update events they're part of, or org admins can update any in their org
      // Platform operators can update any event
      allow update: if isPlatformOperator() ||
                      (isOrgScoped(resource.data.organizationId) &&
                       (isOwner(resource.data.mentorId) ||
                        isOwner(resource.data.menteeId) ||
                        isOrgAdmin(resource.data.organizationId)));
      
      // Users can delete events they're part of, or org admins can delete any in their org
      // Platform operators can delete any event
      allow delete: if isPlatformOperator() ||
                      (isOrgScoped(resource.data.organizationId) &&
                       (isOwner(resource.data.mentorId) ||
                        isOwner(resource.data.menteeId) ||
                        isOrgAdmin(resource.data.organizationId)));
    }
    
    // ==================== RESOURCES ====================
    
    match /resources/{resourceId} {
      // Users can create resources in their organization, platform operators can create anywhere
      allow create: if isAuthenticated() && 
                      (isPlatformOperator() || belongsToOrg(request.resource.data.organizationId));
      
      // Users can read resources in their organization, platform operators can read all
      allow read: if isPlatformOperator() || isOrgScoped(resource.data.organizationId);
      
      // Org admins can update resources in their org, platform operators can update any
      allow update: if isPlatformOperator() || isOrgAdmin(resource.data.organizationId);
      
      // Org admins can delete resources in their org, platform operators can delete any
      allow delete: if isPlatformOperator() || isOrgAdmin(resource.data.organizationId);
    }
    
    // ==================== NOTIFICATIONS ====================
    
    match /notifications/{notificationId} {
      // Users can create notifications in their organization, platform operators can create anywhere
      allow create: if isAuthenticated() && 
                      (isPlatformOperator() || belongsToOrg(request.resource.data.organizationId));
      
      // Users can only read their own notifications, or org admins can read all in their org
      // Platform admins can read all notifications
      allow read: if isPlatformOperator() ||
                     isOwner(resource.data.userId) ||
                     (belongsToOrg(resource.data.organizationId) && isOrgAdmin(resource.data.organizationId));
      
      // Users can update their own notifications, platform operators can update any
      allow update: if isPlatformOperator() || isOwner(resource.data.userId);
      
      // Users can delete their own notifications, platform operators can delete any
      allow delete: if isPlatformOperator() || isOwner(resource.data.userId);
    }
    
    // ==================== INVITATIONS ====================
    
    match /invitations/{invitationId} {
      // Users can create invitations in their organization, platform operators can create anywhere
      allow create: if isAuthenticated() && 
                      (isPlatformOperator() || belongsToOrg(request.resource.data.organizationId));
      
      // Single-document get: org members, platform ops, or anonymous holder of secret link (token == doc id)
      allow get: if isPlatformOperator() ||
                     (isAuthenticated() && isOrgScoped(resource.data.organizationId)) ||
                     (request.auth == null &&
                      resource.data.status == 'Pending' &&
                      resource.data.token == invitationId &&
                      invitationId.size() >= 20);
      
      // Queries / subscriptions: authenticated org members or platform operators only (no anonymous listing)
      allow list: if isPlatformOperator() ||
                     (isAuthenticated() && belongsToOrg(resource.data.organizationId));
      
      // Org admins can update invitations in their org, platform operators can update any
      // Anonymous signup may only change status Pending -> Accepted or Expired (status field only)
      allow update: if isPlatformOperator() ||
                     isOrgAdmin(resource.data.organizationId) ||
                     unauthInvitationStatusUpdate();
      
      // Org admins can delete invitations in their org, platform operators can delete any
      allow delete: if isPlatformOperator() || isOrgAdmin(resource.data.organizationId);
    }
    
    // ==================== RATINGS ====================
    
    match /ratings/{ratingId} {
      // Users can create ratings in their organization, platform operators can create anywhere
      allow create: if isAuthenticated() && 
                      (isPlatformOperator() || belongsToOrg(request.resource.data.organizationId));
      
      // Users can read ratings in their organization, platform operators can read all
      allow read: if isPlatformOperator() || isOrgScoped(resource.data.organizationId);
      
      // Users can update their own ratings, or org admins can update any in their org
      // Platform operators can update any rating
      allow update: if isPlatformOperator() ||
                      (isOrgScoped(resource.data.organizationId) &&
                       (isOwner(resource.data.userId) ||
                        isOrgAdmin(resource.data.organizationId)));
      
      // Users can delete their own ratings, or org admins can delete any in their org
      // Platform operators can delete any rating
      allow delete: if isPlatformOperator() ||
                      (isOrgScoped(resource.data.organizationId) &&
                       (isOwner(resource.data.userId) ||
                        isOrgAdmin(resource.data.organizationId)));
    }
    
    // ==================== CHAT MESSAGES ====================
    
    match /chatMessages/{messageId} {
      // senderId may be a legacy Firestore id while request.auth.uid is the Firebase Auth uid (linked via firebaseAuthUid)
      allow create: if isAuthenticated() && 
                      (isPlatformOperator() || 
                       profileDocActsForOrg(request.resource.data.senderId, request.resource.data.organizationId));
      
      // Users can read messages in their organization, platform operators can read all
      allow read: if isPlatformOperator() || isOrgScoped(resource.data.organizationId);
      
      allow update: if isPlatformOperator() ||
                      profileDocActsForOrg(resource.data.senderId, resource.data.organizationId);
      
      allow delete: if isPlatformOperator() ||
                      profileDocActsForOrg(resource.data.senderId, resource.data.organizationId) ||
                      (isOrgScoped(resource.data.organizationId) &&
                       isOrgAdmin(resource.data.organizationId));
    }
    
    // ==================== TYPING STATUS ====================
    
    match /typingStatus/{typingId} {
      allow create, update: if isAuthenticated() &&
                              (isPlatformOperator() ||
                               profileDocActsForOrg(request.resource.data.userId, request.resource.data.organizationId));
      
      allow delete: if isAuthenticated() &&
                      (isOwner(resource.data.userId) || isPlatformOperator());
      
      // Users can read typing status for chats in their organization
      allow read: if isPlatformOperator() || isOrgScoped(resource.data.organizationId);
    }
    
    // ==================== CHAT GROUPS ====================
    
    match /chatGroups/{groupId} {
      // Users can create groups in their organization, platform operators can create anywhere
      allow create: if isAuthenticated() && 
                      (isPlatformOperator() || belongsToOrg(request.resource.data.organizationId));
      
      // Users can read groups in their organization (membership checked client-side)
      // Platform operators can read all groups
      allow read: if isPlatformOperator() || isOrgScoped(resource.data.organizationId);
      
      // Org admins can update groups in their org, or group members (checked client-side)
      // Platform operators can update any group
      allow update: if isPlatformOperator() || isOrgAdmin(resource.data.organizationId);
      
      // Org admins can delete groups in their org, platform operators can delete any
      allow delete: if isPlatformOperator() || isOrgAdmin(resource.data.organizationId);
    }
    
    // ==================== PRIVATE MESSAGE REQUESTS ====================
    
    match /privateMessageRequests/{requestId} {
      allow create: if isAuthenticated() && 
                      (isPlatformOperator() ||
                       profileDocActsForOrg(request.resource.data.requesterId, request.resource.data.organizationId));
      
      allow read: if isPlatformOperator() ||
                     profileDocActsForOrg(resource.data.requesterId, resource.data.organizationId) ||
                     profileDocActsForOrg(resource.data.recipientId, resource.data.organizationId);
      
      allow update: if isPlatformOperator() ||
                      profileDocActsForOrg(resource.data.recipientId, resource.data.organizationId) ||
                      (isOrgScoped(resource.data.organizationId) &&
                       isOrgAdmin(resource.data.organizationId));
      
      allow delete: if isPlatformOperator() ||
                      profileDocActsForOrg(resource.data.requesterId, resource.data.organizationId) ||
                      (isOrgScoped(resource.data.organizationId) &&
                       isOrgAdmin(resource.data.organizationId));
    }
    
    // ==================== BLOG POSTS (Platform-wide) ====================
    
    match /blogPosts/{postId} {
      // Anyone can read blog posts
      allow read: if true;
      
      // Only platform operators can create/update/delete blog posts
      allow create, update, delete: if isPlatformOperator();
    }
    
    // ==================== DISCUSSION GUIDES ====================
    
    match /discussionGuides/{guideId} {
      // Platform operators can create guides, or org admins can create for their org
      allow create: if isAuthenticated() && 
                      (isPlatformOperator() ||
                       (belongsToOrg(request.resource.data.organizationId) && 
                        isOrgAdmin(request.resource.data.organizationId)));
      
      // Users can read guides in their organization, or platform-wide guides
      // Platform operators can read all guides
      allow read: if isPlatformOperator() ||
                     (resource.data.isPlatform == true || !exists(resource.data.organizationId)) || // Platform-wide
                     isOrgScoped(resource.data.organizationId);
      
      // Platform admins can update any, org admins can update guides in their org
      allow update: if isPlatformOperator() ||
                      (exists(resource.data.organizationId) &&
                       isOrgAdmin(resource.data.organizationId));
      
      // Platform operators can delete any, org admins can delete guides in their org
      allow delete: if isPlatformOperator() ||
                      (exists(resource.data.organizationId) &&
                       isOrgAdmin(resource.data.organizationId));
    }
    
    // ==================== CAREER TEMPLATES ====================
    
    match /careerTemplates/{templateId} {
      // Platform operators can create templates, or org admins can create for their org
      allow create: if isAuthenticated() && 
                      (isPlatformOperator() ||
                       (belongsToOrg(request.resource.data.organizationId) && 
                        isOrgAdmin(request.resource.data.organizationId)));
      
      // Users can read templates in their organization, or platform-wide templates
      // Platform operators can read all templates
      allow read: if isPlatformOperator() ||
                     (resource.data.isPlatform == true || !exists(resource.data.organizationId)) || // Platform-wide
                     isOrgScoped(resource.data.organizationId);
      
      // Platform operators can update any, org admins can update templates in their org
      allow update: if isPlatformOperator() ||
                      (exists(resource.data.organizationId) &&
                       isOrgAdmin(resource.data.organizationId));
      
      // Platform operators can delete any, org admins can delete templates in their org
      allow delete: if isPlatformOperator() ||
                      (exists(resource.data.organizationId) &&
                       isOrgAdmin(resource.data.organizationId));
    }
    
    // ==================== TRAINING VIDEOS ====================
    
    match /trainingVideos/{videoId} {
      // Platform operators can create videos, or org admins can create for their org
      allow create: if isAuthenticated() && 
                      (isPlatformOperator() ||
                       (belongsToOrg(request.resource.data.organizationId) && 
                        isOrgAdmin(request.resource.data.organizationId)));
      
      // Users can read videos in their organization, or platform-wide videos
      // Platform admins can read all videos
      allow read: if isPlatformOperator() ||
                     (resource.data.isPlatform == true || !exists(resource.data.organizationId)) || // Platform-wide
                     isOrgScoped(resource.data.organizationId);
      
      // Platform operators can update any, org admins can update videos in their org
      allow update: if isPlatformOperator() ||
                      (exists(resource.data.organizationId) &&
                       isOrgAdmin(resource.data.organizationId));
      
      // Platform operators can delete any, org admins can delete videos in their org
      allow delete: if isPlatformOperator() ||
                      (exists(resource.data.organizationId) &&
                       isOrgAdmin(resource.data.organizationId));
    }
    
    // ==================== TOTP SECRETS (2FA) ====================
    // Client never reads/writes - only Cloud Functions (Admin SDK) access
    match /totpSecrets/{userId} {
      allow read, write: if false;
    }

    // ==================== SYSTEM LOGS ====================
    
    match /system_logs/{logId} {
      // Allow authenticated users to create logs (for error logging)
      allow create: if isAuthenticated();
      
      // Only platform operators can read logs
      allow read: if isPlatformOperator();
      
      // No updates or deletes allowed
      allow update, delete: if false;
    }
  }
}
