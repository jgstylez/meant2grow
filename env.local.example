# Local Development Environment Configuration
# Copy this file to .env.local and fill in the actual values
# This is used for local development only

# Google OAuth Client ID (Local Development)
# Use sandbox OAuth client for local development
VITE_GOOGLE_CLIENT_ID=493534533344-e2mcmbht3802t1fhdmtq9rgrf0ljc1qe.apps.googleusercontent.com

# Firebase Config (Local Development - typically uses sandbox project)
# Get these from Firebase Console > Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=meant2grow-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=meant2grow-dev
VITE_FIREBASE_STORAGE_BUCKET=meant2grow-dev.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID_HERE
VITE_FIREBASE_APP_ID=YOUR_APP_ID_HERE

# Firebase Cloud Messaging VAPID Key (for push notifications)
# Generate this key in Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
# Click "Generate key pair" and copy the key here
VITE_FIREBASE_VAPID_KEY=YOUR_VAPID_KEY_HERE

# Functions URL (used by Vite dev proxy target and production builds).
# Should match your Firebase project: https://us-central1-${VITE_FIREBASE_PROJECT_ID}.cloudfunctions.net
# If omitted, the app and Vite proxy derive this from VITE_FIREBASE_PROJECT_ID (defaults to meant2grow-dev).
VITE_FUNCTIONS_URL=https://us-central1-meant2grow-dev.cloudfunctions.net
# Dev: leave unset — the app calls /api/functions/* on the Vite server, which proxies to VITE_FUNCTIONS_URL (avoids CORS from localhost).
# Set to "true" only if you run `firebase emulators:start --only functions` and want the client to hit the emulator directly.
# VITE_FUNCTIONS_USE_EMULATOR=true
#
# In-app video (VideoSDK) — requires the videoCallSession HTTPS function on the SAME project as VITE_FIREBASE_PROJECT_ID.
# If "Start call now" shows a 404 toast, that function is missing from this project (a generic `firebase deploy --only functions`
# can still omit it if that export failed). Deploy only it: npm run firebase:deploy:videoCallSession
# Prereqs: firebase functions:secrets:set VIDEO_SDK_SECRET (VideoSDK secret from dashboard)
#         firebase functions:config:set (or Firebase Console → Functions) for VIDEO_SDK_API_KEY if not using .env defaults

# MailerSend Configuration
# Get your API token from: https://app.mailersend.com/api-tokens
# Note: These variables need VITE_ prefix to be accessible in the browser
VITE_MAILERSEND_API_TOKEN=mailersend_api_key_here
VITE_MAILERSEND_FROM_EMAIL=noreply@meant2grow.com  # Must be verified in MailerSend
VITE_MAILERSEND_REPLY_TO_EMAIL=support@meant2grow.com
VITE_APP_URL=http://localhost:5173  # Your app URL for email links (local development)

# Note: For sandbox and production deployments, use .env.sandbox.example and .env.production.example respectively

# Flowglad Configuration (Billing & Payments)
# Get your API keys from: https://app.flowglad.com/settings/api-keys
# Get your webhook secret from: https://app.flowglad.com/settings/webhooks
FLOWGLAD_SECRET_KEY=your_flowglad_key_here
FLOWGLAD_WEBHOOK_SECRET=

# Flowglad Price IDs (create these in your Flowglad dashboard)
FLOWGLAD_PRICE_STARTER_MONTHLY=price_starter_monthly
FLOWGLAD_PRICE_STARTER_YEARLY=price_starter_yearly
FLOWGLAD_PRICE_PRO_MONTHLY=price_pro_monthly
FLOWGLAD_PRICE_PRO_YEARLY=price_pro_yearly
FLOWGLAD_PRICE_BUSINESS_MONTHLY=price_business_monthly
FLOWGLAD_PRICE_BUSINESS_YEARLY=price_business_yearly

# GIPHY API Key (for GIF picker in chat)
# Get your free API key from: https://developers.giphy.com/
VITE_GIPHY_API_KEY=your_giphy_api_key_here

