# Production Environment Configuration
# Copy this file to .env.production and fill in the actual values
# This is used for production deployments (meant2grow.com)
# WARNING: This is for PRODUCTION - use with caution!

# Google OAuth Client ID (Production)
# Get this from Google Cloud Console > APIs & Services > Credentials
# Use the OAuth 2.0 Client ID configured for meant2grow.com
VITE_GOOGLE_CLIENT_ID=YOUR_PRODUCTION_GOOGLE_CLIENT_ID_HERE

# Firebase Config (Production - meant2grow-prod project)
# Get these from Firebase Console > Project Settings > General > Your apps > Web app
# Project: meant2grow-prod
VITE_FIREBASE_API_KEY=YOUR_PRODUCTION_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=meant2grow-prod.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=meant2grow-prod
VITE_FIREBASE_STORAGE_BUCKET=meant2grow-prod.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_PRODUCTION_SENDER_ID_HERE
VITE_FIREBASE_APP_ID=YOUR_PRODUCTION_APP_ID_HERE

# Firebase Cloud Messaging VAPID Key (for push notifications)
# Generate this key in Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
# Click "Generate key pair" and copy the key here
VITE_FIREBASE_VAPID_KEY=YOUR_PRODUCTION_VAPID_KEY_HERE

# Functions URL (Production)
VITE_FUNCTIONS_URL=https://us-central1-meant2grow-prod.cloudfunctions.net

# App URL (Production)
VITE_APP_URL=https://meant2grow.com

# MailerSend Configuration (Production)
# Get your API token from: https://app.mailersend.com/api-tokens
# Note: These variables need VITE_ prefix to be accessible in the browser
VITE_MAILERSEND_API_TOKEN=your_production_mailersend_api_key_here
VITE_MAILERSEND_FROM_EMAIL=noreply@meant2grow.com  # Must be verified in MailerSend
VITE_MAILERSEND_REPLY_TO_EMAIL=support@meant2grow.com

# GIPHY API Key (for GIF picker in chat)
# Get your free API key from: https://developers.giphy.com/
VITE_GIPHY_API_KEY=your_giphy_api_key_here

# Flowglad Configuration (Billing & Payments)
# Get your API keys from: https://app.flowglad.com/settings/api-keys
# Get your webhook secret from: https://app.flowglad.com/settings/webhooks
# Use production keys for production environment
FLOWGLAD_SECRET_KEY=your_production_flowglad_key_here
FLOWGLAD_WEBHOOK_SECRET=whsec_your_production_webhook_secret_here

# Flowglad Price IDs (create these in your Flowglad dashboard)
# Use production price IDs for production environment
FLOWGLAD_PRICE_STARTER_MONTHLY=price_production_starter_monthly
FLOWGLAD_PRICE_STARTER_YEARLY=price_production_starter_yearly
FLOWGLAD_PRICE_PRO_MONTHLY=price_production_pro_monthly
FLOWGLAD_PRICE_PRO_YEARLY=price_production_pro_yearly
FLOWGLAD_PRICE_BUSINESS_MONTHLY=price_production_business_monthly
FLOWGLAD_PRICE_BUSINESS_YEARLY=price_production_business_yearly
